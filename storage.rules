rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ========== LAUDOS (Análises de Solo) ==========
    // Path: /laudos_solo/{fazendaId}/{piqueteId}/{laudoId}.pdf
    match /laudos_solo/{fazendaId}/{piqueteId}/{allPaths=**} {
      
      // Pecuarista lê laudos de suas fazendas
      allow read: if request.auth != null &&
                     request.auth.uid in 
                       firestore.get(/databases/(default)/documents/fazendas/$(fazendaId)).data.proprietario_id;
      
      // Supervisor escreve laudos nas fazendas atribuídas
      allow write: if request.auth != null &&
                      request.auth.uid in 
                        firestore.get(/databases/(default)/documents/fazendas/$(fazendaId)).data.supervisores;
    }
    
    // ========== LAUDOS SATÉLITE (Imagens NDVI) ==========
    // Path: /imagens_satelite/{fazendaId}/{piqueteId}/{dataLeitura}.tif
    match /imagens_satelite/{fazendaId}/{piqueteId}/{allPaths=**} {
      
      allow read: if request.auth != null &&
                     (request.auth.uid in 
                       firestore.get(/databases/(default)/documents/fazendas/$(fazendaId)).data.proprietario_id ||
                      request.auth.uid in 
                       firestore.get(/databases/(default)/documents/fazendas/$(fazendaId)).data.supervisores);
      
      allow write: if request.auth != null &&
                      request.auth.uid in 
                        firestore.get(/databases/(default)/documents/fazendas/$(fazendaId)).data.supervisores;
    }
    
    // ========== DEFAULT DENY ==========
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}